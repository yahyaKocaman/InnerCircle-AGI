# ── App ────────────────────────────────────────────────────────
APP_NAME=InnerCircle AGI
APP_VERSION=1.0.0
DEBUG=false

# ── Database (local dev) ───────────────────────────────────────
DATABASE_URL=sqlite:///./innercircle.db

# ── Security ───────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-please-change-in-production-32chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Ollama ─────────────────────────────────────────────────────
# Local dev (not in Docker):
OLLAMA_BASE_URL=http://localhost:11434
# Inside Docker containers:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_MODELS=D:\ollama\models
OLLAMA_TIMEOUT=120

# ── ChromaDB ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ── Redis / Celery ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Insight Generation ─────────────────────────────────────────
INSIGHT_GENERATION_INTERVAL_HOURS=6
MAX_INSIGHTS_PER_AGENT=3