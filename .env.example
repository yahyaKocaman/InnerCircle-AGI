# ─────────────────────────────────────────────────────────────
#  InnerCircle AGI — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit the .env file to version control!
# ─────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
APP_NAME=InnerCircle AGI
APP_VERSION=1.0.0
DEBUG=false

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-minimum-32chars-required!!

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/innercircle

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Ollama (Local LLM) ───────────────────────────────────────
# Ollama runs on your HOST machine, not in Docker.
#
# Setup steps:
#   1. Install Ollama: https://ollama.ai
#   2. Pull the model: ollama pull deepseek-r1:8b
#   3. Start server:   ollama serve
#
# Docker containers access host via host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_TIMEOUT=180

# ── ChromaDB (Vector Memory) ─────────────────────────────────
CHROMA_PERSIST_DIR=/app/chroma_data

# ── Insight Generation ───────────────────────────────────────
INSIGHT_GENERATION_INTERVAL_HOURS=6
MAX_INSIGHTS_PER_AGENT=3

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Monitoring (optional, --profile monitoring) ───────────────
GRAFANA_PASSWORD=innercircle
